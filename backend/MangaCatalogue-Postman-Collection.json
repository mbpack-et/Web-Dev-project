{
  "info": {
    "name": "Manga Catalogue Django API",
    "description": "Full API coverage for MangaBase backend (Django + DRF + JWT). Set collection variables after Login or Register.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "manga_id", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_reader\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/register/"
          },
          "response": [
            {
              "name": "201 Created",
              "originalRequest": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"username\": \"demo_reader\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"securepass123\"\n}"
                },
                "url": "{{base_url}}/api/auth/register/"
              },
              "status": "Created",
              "code": 201,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"user\": {\n    \"id\": 2,\n    \"username\": \"demo_reader\",\n    \"email\": \"demo@example.com\"\n  },\n  \"tokens\": {\n    \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_refresh\",\n    \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_access\"\n  }\n}"
            },
            {
              "name": "400 Validation error",
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"username\": [\"A user with that username already exists.\"]\n}"
            }
          ]
        },
        {
          "name": "Login (JWT obtain pair)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo_reader\",\n  \"password\": \"securepass123\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/"
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_refresh\",\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.example_access\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"detail\": \"No active account found with the given credentials\"\n}"
            }
          ]
        },
        {
          "name": "Refresh access token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh/"
          },
          "response": [
            {
              "name": "200 OK (with rotation)",
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.new_access\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.new_refresh\"\n}"
            },
            {
              "name": "401 Token blacklisted",
              "status": "Unauthorized",
              "code": 401,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"detail\": \"Token is blacklisted\",\n  \"code\": \"token_not_valid\"\n}"
            }
          ]
        },
        {
          "name": "Logout (blacklist refresh)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/logout/"
          },
          "response": [
            {
              "name": "205 Reset Content",
              "status": "Reset Content",
              "code": 205,
              "_postman_previewlanguage": "plain",
              "header": [],
              "body": ""
            },
            {
              "name": "400 Missing refresh",
              "status": "Bad Request",
              "code": 400,
              "_postman_previewlanguage": "json",
              "body": "{\n  \"detail\": \"Refresh token required.\"\n}"
            }
          ]
        }
      ]
    },
