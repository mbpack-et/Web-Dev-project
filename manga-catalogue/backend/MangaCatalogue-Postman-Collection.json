{
  "info": {
    "name": "Manga Catalogue Django API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/auth/login/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "auth", "login", ""]
        }
      },
      "response": []
    },
    {
      "name": "Get Manga List",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8000/api/manga/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "manga", ""]
        }
      },
      "response": []
    },
    {
      "name": "Create Manga",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"My New Manga\",\n  \"author_id\": 1,\n  \"genre_ids\": [1, 2],\n  \"status\": \"ONGOING\",\n  \"summary\": \"A new adventure story.\",\n  \"rating\": 4.5,\n  \"chapters\": 12,\n  \"published\": \"2024-present\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/manga/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "manga", ""]
        }
      },
      "response": []
    },
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "Authorization", "value": "Bearer {{access_token}}"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"score\": 9,\n  \"comment\": \"Very engaging story.\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/manga/1/reviews/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "manga", "1", "reviews", ""]
        }
      },
      "response": []
    },
    {
      "name": "User Reading List",
      "request": {
        "method": "GET",
        "header": [
          {"key": "Authorization", "value": "Bearer {{access_token}}"}
        ],
        "url": {
          "raw": "http://localhost:8000/api/reading-list/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "reading-list", ""]
        }
      },
      "response": []
    }
  ]
}
